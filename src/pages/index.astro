---
import { Hero } from '@/partials/Hero';
import { TrustedBy } from '@/partials/TrustedBy';
import { HowItWorks } from '@/partials/HowItWorks';
import { Features } from '@/partials/Features';
import { FeatureShowcase } from '@/partials/FeatureShowcase';
import { Pricing } from '@/partials/Pricing';
import { Integrations } from '@/partials/Integrations';
import { Testimonials } from '@/partials/Testimonials';
import { FAQ } from '@/partials/FAQ';
import { BlogPreview } from '@/partials/BlogPreview';
import { CTA } from '@/partials/CTA';
import Base from '@/templates/Base.astro';
---

<Base
  head={{
    title: 'AI Studio – AI-Powered Design Assistant',
    description: 'Unlock your creative potential. Seamlessly generate, customize, and perfect your designs with cutting-edge AI technology.',
  }}
>
  <Hero />
  <TrustedBy />
  <HowItWorks />
  <Features />
  <FeatureShowcase />
  <Pricing client:load />
  <Integrations />
  <Testimonials />
  <FAQ />
  <BlogPreview />
  <CTA />
</Base>
