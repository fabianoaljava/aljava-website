---
import Base from '@/templates/Base.astro';
const updated = 'April 2025';
---

<Base
  head={{
    title: 'Privacy Policy — Aljava Studio',
    description: 'How Aljava Studio collects, uses and protects your personal information.',
  }}
>
  <section style="background-color: #091722; min-height: calc(100vh - 140px);">
    <div class="mx-auto max-w-[760px] px-5 py-24 md:px-8 md:py-32">

      <p
        class="mb-4 text-sm font-semibold uppercase tracking-widest"
        style="font-family: 'Inter', sans-serif; color: #2A9D8F;"
      >
        Legal
      </p>
      <h1
        style="font-family: 'Outfit', sans-serif; font-size: clamp(2rem, 4vw, 3rem); color: #FFFFFF; font-weight: 600; line-height: 1.15; margin: 0 0 0.75rem;"
      >
        Privacy Policy
      </h1>
      <p class="mb-12 text-sm" style="font-family: 'Inter', sans-serif; color: #94A3B8;">
        Last updated: {updated}
      </p>

      <div
        class="prose-legal flex flex-col gap-10"
        style="font-family: 'Inter', sans-serif;"
      >
        {[
          {
            title: '1. Who we are',
            body: 'Aljava Studio ("we", "us", "our") provides website design and management services. This policy explains how we collect and use personal information when you interact with our website or services.',
          },
          {
            title: '2. Information we collect',
            body: 'We collect information you provide directly — such as your name, email address and business details when you submit our contact form. We may also collect standard technical data through analytics tools, including your browser type, IP address and pages visited.',
          },
          {
            title: '3. How we use your information',
            body: 'We use your information to respond to your enquiries, set up and manage your website, communicate updates and improvements, and improve our services. We will never sell your data to third parties.',
          },
          {
            title: '4. Data sharing',
            body: 'We may share your information with trusted third-party tools that help us deliver our services (for example, hosting providers or email platforms). These partners are bound by their own privacy policies and only process data on our instructions.',
          },
          {
            title: '5. Cookies',
            body: 'Our website uses cookies to understand how visitors use the site. You can control cookie settings through your browser at any time.',
          },
          {
            title: '6. Data retention',
            body: 'We keep your data for as long as is necessary to provide our services or as required by law. You can request deletion of your data at any time.',
          },
          {
            title: '7. Your rights',
            body: 'You have the right to access, correct or delete the personal information we hold about you. To make a request, email us at hello@aljava.studio.',
          },
          {
            title: '8. Changes to this policy',
            body: 'We may update this policy from time to time. We will notify you of significant changes by updating the date at the top of this page.',
          },
          {
            title: '9. Contact',
            body: 'If you have any questions about this policy, please contact us at hello@aljava.studio.',
          },
        ].map((section) => (
          <div class="flex flex-col gap-3">
            <h2
              style="font-family: 'Outfit', sans-serif; font-size: 1.2rem; font-weight: 600; color: #FFFFFF; margin: 0;"
            >
              {section.title}
            </h2>
            <p class="text-base leading-relaxed" style="color: #94A3B8; margin: 0;">
              {section.body}
            </p>
          </div>
        ))}
      </div>

    </div>
  </section>
</Base>
